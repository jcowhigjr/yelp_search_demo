  core
  dotnet
  gem
  github
  gitlab
  go
  npm
  pipx
  spm
  http
  ubi
  vfox

plugins:

toolset:
  core:ruby@3.3.10

path:
  ~/.local/share/mise/installs/ruby/3.3.10/bin
  ~/.local/share/mise/installs/ruby/3.3.10/bin
