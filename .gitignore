/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore git hooks generated by lefthook
.githooks/

# Ignore mise.toml backup file
mise.toml.backup
# Python
__pycache__/
*.pyc
*.py

# Project specific
.project/*
!.project/config/
!.project/config/**

# Local agent/editor caches and logs (not for git)
.claude/
.cursor/
.mcp-cache/
act-logs/

# Local design/prototype artifacts
Website Design Improvement/

# Local sqlite/WAL scratch files created during experiments
nil-*

# Local MCP/config and analysis outputs
.mcp.json
ci_stability_results.txt
github_issues_open.json
monte_carlo_value_scores_*.json
quick_test_results.json
test_workflow.txt
dev.log
