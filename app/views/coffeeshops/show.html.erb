<% content_for :body_class, 'landing-body' %>

<div class="container mx-auto px-4 py-8">
  <!-- Back to Results Button -->
  <div class="mb-6">
    <%= link_to "← BACK TO RESULTS", "javascript:history.back()", class: "inline-flex items-center px-4 py-2 bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-600 transition-colors" %>
  </div>
  
  <div class="flex flex-col lg:flex-row lg:space-x-8">
    <!-- Left Column: Image -->
    <div class="lg:w-1/2">
      <%= image_tag @coffeeshop.image_url, alt: @coffeeshop.name, class: 'w-full h-auto rounded-lg shadow-lg' %>
    </div>

    <!-- Right Column: Details -->
    <div class="lg:w-1/2 mt-8 lg:mt-0">
      <div class="flex items-center gap-3">
        <h1 class="page-name"><%= @coffeeshop.name %></h1>
        <% if logged_in? && current_user.favorite?(@coffeeshop) %>
          <i class="material-icons text-red-500" aria-label="Favorited">favorite</i>
        <% else %>
          <i class="material-icons text-gray-400" aria-label="Not favorited">favorite_border</i>
        <% end %>
      </div>

      <!-- About Section -->
      <div class="mt-4" data-testid="about-section">
        <h2 class="page-text font-bold text-xl mb-2">About</h2>
        <div class="space-y-4">
          <% google_maps_url = "https://www.google.com/maps/search/?api=1&query=#{@coffeeshop.google_address_slug}" %>
          <% phone_url = "tel:#{number_to_phone(@coffeeshop.phone_number, area_code: true)}" %>
          <div class="flex items-center">
            <i class="material-icons mr-2">place</i>
            <%= link_to @coffeeshop.address, google_maps_url, target: :blank, class: "page-text truncate" %>
          </div>
          <div class="flex items-center mt-3">
            <i class="material-icons mr-2">phone</i>
            <%= link_to number_to_phone(@coffeeshop.phone_number, area_code: true), phone_url, class: "page-text truncate" %>
          </div>
          
          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <%= link_to "GET DIRECTIONS", google_maps_url, target: :blank, class: "flex-1 text-center px-4 py-3 bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-600 transition-colors" %>
            <%= link_to "CALL NOW", phone_url, class: "flex-1 text-center px-4 py-3 border-2 border-blue-500 text-blue-500 font-medium rounded-lg hover:bg-blue-50 transition-colors" %>
          </div>
          <div class="flex items-center">
             <i class="fab fa-yelp yelp_color mr-2"></i>
            <% begin %>
              <% yelp_uri = URI.parse(@coffeeshop.yelp_url) %>
              <% if yelp_uri.scheme == 'https' && yelp_uri.host == 'www.yelp.com' %>
                <% safe_yelp_url = "https://www.yelp.com" + yelp_uri.path.to_s + (yelp_uri.query ? "?" + yelp_uri.query : "") %>
                <%= link_to "View on Yelp", safe_yelp_url, target: :blank, class: "page-text" %>
              <% end %>
            <% rescue URI::InvalidURIError %>
              <%# Malformed Yelp URL, do not render link %>
            <% end %>
          </div>
          <div class="flex items-center">
             <i class="material-icons mr-2">star</i>
            <%= render partial: 'rating', locals: { rating: @coffeeshop.rating, review_count: @coffeeshop.reviews.size } %>
          </div>
           <div class="flex items-center">
            <% if @coffeeshop.user_favorites.size > 0 %>
              <i class="material-icons mr-2">favorite</i>
              <span class="page-text"><%= pluralize(@coffeeshop.user_favorites.size, "Favorite") %></span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Favorites Section -->
      <div class="mt-8">
         <% if !logged_in? %>
              <span class="page-text">
                <%= link_to t('.login-to-add-th'), login_path %>
              </span>
            <% else %>
              <!-- Add to user favorites -->
              <%= turbo_frame_tag :user_favorite do %>
                <div class="row center">
                  <% if current_user.favorite?(@coffeeshop) %>
                    <%= form_tag user_favorite_path, method: 'delete' do %>
                      <%= hidden_field_tag :coffeeshop_id, @coffeeshop.id %>
                      <%= submit_tag t('.remove-from-favorites'), class: 'btn-large' %>
                    <% end %>
                  <% else %>
                    <%= form_tag user_favorites_path do %>
                      <%= hidden_field_tag :coffeeshop_id, @coffeeshop.id %>
                      <%= submit_tag t('.add-to-favorites'), class: 'btn-large' %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="mt-12">
    <h2 class="page-text font-bold text-xl mb-4 text-center">Reviews</h2>
    <div class="space-y-4">
       <% if @coffeeshop.reviews.empty? %>
          <div class="text-center page-text">
            <p>No reviews yet. Be the first to write one!</p>
          </div>
        <% else %>
          <% @coffeeshop.reviews.each do |review| %>
            <div class="review-container shadow-md">
              <%= render partial: 'reviews/show', locals: { review: } %>
            </div>
          <% end %>
        <% end %>

      <% if !logged_in? %>
         <span class="page-text red-text">
            <%= link_to t('.log-in'), login_path %>
            <%= t('.to-leave-a-revi') %>
          </span>
      <% else %>
        <div class="review-container shadow-md">
          <%= render partial: 'reviews/form', locals: { coffeeshop: @coffeeshop, review: Review.new } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
