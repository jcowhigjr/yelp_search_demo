<div class="coffeeshop-card" id="<%= dom_id(coffeeshop) %>">
  <div class="card-image">
    <%= image_tag coffeeshop.large_image_url,
                  alt: coffeeshop.name,
                  class: 'w-full h-full object-cover' %>
  </div>

  <div class="card-content">
    <div class="card-title-group">
      <div>
        <p class="card-kicker">Top rated pick</p>
        <h3 class="card-title">
          <%= link_to coffeeshop.name, coffeeshop_path(coffeeshop),
                      data: { turbo: false },
                      class: 'coffeeshop-link' %>
        </h3>
      </div>

      <div class="rating-pill" aria-label="Rating">
        <i class="material-icons" aria-hidden="true">star</i>
        <span><%= coffeeshop.rating %></span>
      </div>
    </div>

    <% if logged_in? %>
      <div class="favorite-section">
        <%= turbo_frame_tag dom_id(coffeeshop, 'favorite') do %>
          <%= render 'favorites/button',
                     item: coffeeshop,
                     icon: favorite_icon_for(local_assigns[:search_query]),
                     liked: current_user.favorited?(coffeeshop),
                     search_query: local_assigns[:search_query] %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="card-action">
    <div class="info-section">
      <div class="info-item">
        <i class="material-icons info-icon">place</i>
        <%= link_to "https://www.google.com/maps/search/?api=1&query=#{coffeeshop.google_address_slug}",
                    target: :blank,
                    rel: 'noopener',
                    class: 'map-link card-contact-link' do %>
          <%= coffeeshop.address %>
        <% end %>
      </div>

      <div class="info-item">
        <i class="material-icons info-icon">phone</i>
        <% phone_digits = coffeeshop.phone_number.to_s.gsub(/\D/, '') %>
        <% if phone_digits.present? %>
          <%= link_to "tel:#{phone_digits}",
                      class: 'phone-link card-contact-link' do %>
            <%= number_to_phone(coffeeshop.phone_number, area_code: true) %>
          <% end %>
        <% else %>
          <span class="phone-unavailable">Phone unavailable</span>
        <% end %>
      </div>
    </div>

    <div class="card-actions-row">
      <%= link_to t('coffeeshops.coffeeshop.more-info'),
                  coffeeshop_path(coffeeshop),
                  data: { turbo: false },
                  class: 'material-button large w-full' %>
      <%= link_to 'Open in Yelp',
                  coffeeshop.yelp_url,
                  target: :blank,
                  rel: 'noopener',
                  class: 'material-button large secondary card-secondary-action' %>
    </div>
  </div>
</div>
