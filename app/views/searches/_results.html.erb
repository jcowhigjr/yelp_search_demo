<div class="container mx-auto px-4 py-8">
  <div class="max-w-6xl mx-auto">
    <div class="mb-8">
      <%= render 'searches/form' %>
    </div>

    <div class="search-results-masthead mb-6">
      <div class="search-results-masthead__copy">
        <p class="search-results-masthead__eyebrow"><%= t('views.searches.results_masthead.eyebrow') %></p>
        <h2 class="search-results-masthead__heading"><%= t('views.searches.results_masthead.heading') %></h2>
        <div class="search-results-masthead__meta">
          <span class="search-results-masthead__meta-pill">
            <span class="material-icons search-results-masthead__meta-icon" aria-hidden="true">search</span>
            <%= t('views.searches.results_masthead.query_label') %> <strong><%= @search.query %></strong>
          </span>
          <span class="search-results-masthead__meta-pill">
            <span class="material-icons search-results-masthead__meta-icon" aria-hidden="true">place</span>
            <%= t('views.searches.results_masthead.near_you') %>
          </span>
          <span class="search-results-masthead__meta-pill" data-testid="results-summary">
            <span class="material-icons search-results-masthead__meta-icon" aria-hidden="true">storefront</span>
            <%= t('views.searches.results_masthead.result_count', count: @search.coffeeshops.length) %>
          </span>
        </div>
      </div>
    </div>

    <% if @search.coffeeshops.empty? %>
      <div class="text-center">
        <span class="page-text" style="color: var(--color-text);">
          <%= t('.no-results-found') %>
        </span>
      </div>
    <% else %>
      <%= turbo_stream_from 'coffeeshops' %>
      <%= turbo_frame_tag 'coffeeshops' do %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 search-results-grid">
          <% @search.coffeeshops.each do |coffeeshop| %>
            <%= render partial: 'coffeeshops/coffeeshop_card', locals: { coffeeshop:, search_query: @search.query } %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
