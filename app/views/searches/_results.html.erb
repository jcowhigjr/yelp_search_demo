<div class="container mx-auto px-4 py-8">
  <div class="max-w-6xl mx-auto">
    <div class="mb-8">
      <%= render 'searches/form' %>
    </div>

    <div class="search-results-masthead mb-6">
      <div class="search-results-masthead__copy">
        <p class="search-results-masthead__eyebrow">Fresh picks for your next stop</p>
        <h2 style="color: var(--color-text);">
          <%= t('views.searches.results', query: @search.query) %>
        </h2>
        <p class="search-results-masthead__summary">
          Top-rated spots with direct actions for maps, calls, and details.
        </p>
        <div class="search-results-masthead__meta">
          <span class="search-results-masthead__meta-pill">
            Query: <strong><%= @search.query %></strong>
          </span>
          <span class="search-results-masthead__meta-pill">Sorted by Yelp rating</span>
        </div>
      </div>

      <div class="search-results-masthead__stats" data-testid="results-summary">
        <span class="search-results-masthead__stat-value"><%= @search.coffeeshops.length %></span>
        <span class="search-results-masthead__stat-label"><%= 'result'.pluralize(@search.coffeeshops.length) %> found</span>
      </div>
    </div>

    <% if @search.coffeeshops.empty? %>
      <div class="text-center">
        <span class="page-text" style="color: var(--color-text);">
          <%= t('.no-results-found') %>
        </span>
      </div>
    <% else %>
      <%= turbo_stream_from 'coffeeshops' %>
      <%= turbo_frame_tag 'coffeeshops' do %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 search-results-grid">
          <% @search.coffeeshops.each do |coffeeshop| %>
            <%= render partial: 'coffeeshops/coffeeshop_card', locals: { coffeeshop:, search_query: @search.query } %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
