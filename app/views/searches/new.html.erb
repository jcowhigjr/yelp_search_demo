<div class="container mx-auto px-4 py-8">
  <% if flash[:error] %>
    <div class="row center mb-6">
      <span class="page-text red-text"><%= flash[:error] %></span>
    </div>
  <% end %>

  <h2 class="text-xs text-transparent"><%= t('views.searches.new') %></h2>

  <div class="text-center">
    <h1 class="page-name mb-8">
      COFFEE NEAR YOU!
    </h1>

    <p class="page-text mb-12" style="opacity: 0.8;">
      Find the best coffee shops in your area
    </p>

    <div class="max-w-3xl mx-auto mb-8">
      <%= render 'searches/form', locals: { search: @search } if @search %>
    </div>

    <!-- Feature icons section -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-12">
      <div class="text-center">
        <div 
          class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-3"
          style="background-color: var(--color-primary); opacity: 0.2;"
        >
          <span class="text-4xl">☕</span>
        </div>
        <p style="color: var(--color-text); opacity: 0.7;">
          Search nearby
        </p>
      </div>

      <div class="text-center">
        <div 
          class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-3"
          style="background-color: var(--color-primary); opacity: 0.2;"
        >
          <span class="text-4xl">⭐</span>
        </div>
        <p style="color: var(--color-text); opacity: 0.7;">
          Read reviews
        </p>
      </div>

      <div class="text-center">
        <div 
          class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-3"
          style="background-color: var(--color-primary); opacity: 0.2;"
        >
          <span class="text-4xl">❤️</span>
        </div>
        <p style="color: var(--color-text); opacity: 0.7;">
          Save favorites
        </p>
      </div>
    </div>
  </div>
</div>
