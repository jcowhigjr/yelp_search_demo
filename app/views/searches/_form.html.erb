<div class="form-group">
  <%= form_for @search,
               html: {
                 class: 'w-full search-bar-container',
                 data: { turbo: false, controller: 'search-form geolocation' },
               } do |f| %>
    <div class="search-bar">
      <button type="button" class="geolocation-button" data-action="geolocation#geolocate" aria-label="Use my current location">
        <i class="material-icons">my_location</i>
      </button>

      <%= f.search_field :query,
                         placeholder: t('views.searches.placeholder'),
                         required: true,
                         class: 'search-input',
                         data: {
                           'search-form-target': 'input',
                           action: 'input->search-form#toggleClearButton',
                         } %>

      <%= link_to new_search_path,
                  method: :get,
                  class: 'clear-button clear-button-hidden',
                  data: {
                    turbo_frame: dom_id(@search),
                    'search-form-target': 'clearButton',
                  },
                  aria: { label: t('views.searches.clear', default: 'Clear') } do %>
        <i class="material-icons">clear</i>
      <% end %>

      <%= f.button :submit, class: 'search-button', aria: { label: t('views.searches.submit', default: 'Search') } do %>
        <i class="material-icons">search</i>
      <% end %>
    </div>

    <div class="search-bar-meta">
      <span>Tip: try "espresso", "wifi", or "pastries".</span>
      <span>Location sharing narrows results faster.</span>
      <span class="geolocation-status-chip geolocation-status-chip--idle"
            data-geolocation-target="status"
            data-state="idle"
            aria-live="polite">
        Checking location...
      </span>
    </div>

    <div>
      <%= f.hidden_field :latitude, "data-geolocation-target": 'latitude' %>
      <%= f.hidden_field :longitude,  "data-geolocation-target": 'longitude' %>
    </div>
  <% end %>
</div>
