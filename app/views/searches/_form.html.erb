<div class="form-group">
  <%= form_for @search, html: { class: "w-full" } do |f| %>
    <div
      class="inline-flex w-full items-center gap-2 rounded-xl border px-4 py-2 bg-white shadow-sm focus-within:shadow-md"
    >
      <i class="material-icons text-gray-600" aria-hidden="true">search</i>

      <%= f.search_field :query,
                         placeholder: t('views.searches.placeholder'),
                         required: true,
                         class: "flex-1 border-0 outline-none bg-transparent text-base",
                         data: { turbo: false } %>

      <%= link_to new_search_path,
                  method: :get,
                  class: "px-2 text-gray-500 hover:text-gray-700",
                  data: { turbo_frame: dom_id(@search) } do %>
        <i class="material-icons" aria-label="<%= t('views.searches.clear', default: 'Clear') %>">clear</i>
      <% end %>

      <%= f.button :submit,
                   class: "ml-2 rounded-lg px-4 py-2 text-sm font-semibold text-white bg-blue-700 hover:bg-blue-800",
                   data: { turbo: false } do %>
        <span class="hidden sm:inline"><%= t('views.searches.submit', default: 'Search') %></span>
        <i class="material-icons sm:hidden" aria-hidden="true">search</i>
      <% end %>
    </div>

    <div data-controller="geolocation">
      <%= f.hidden_field :latitude, "data-geolocation-target": 'latitude' %>
      <%= f.hidden_field :longitude,  "data-geolocation-target": 'longitude' %>
    </div>
  <% end %>
</div>
