<% content_for :body_class, 'auth-body' %>
<div class="container mx-auto px-4 py-8">
  <div class="max-w-md mx-auto">
    <div class="auth-container">
      <h1 class="page-name text-center mb-8">Sign Up</h1>

      <% if flash[:error] %>
        <div class="alert-error">
          <%= flash[:error] %>
        </div>
      <% end %>

      <%= form_for @user, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :name, "Name", class: "form-label" %>
          <%= f.text_field :name, 
              placeholder: "Your name",
              required: true,
              class: "material-input" %>
        </div>

        <div>
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, 
              placeholder: "your@email.com",
              required: true,
              class: "material-input" %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "form-label" %>
          <%= f.password_field :password, 
              placeholder: "••••••••",
              required: true,
              class: "material-input" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
          <%= f.password_field :password_confirmation, 
              placeholder: "••••••••",
              required: true,
              class: "material-input" %>
        </div>

        <div class="mt-8">
          <%= f.submit 'Sign Up', class: 'material-button large w-full' %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "Already have an account? Login here", login_path, class: "form-link" %>
      </div>

      <div class="mt-8">
        <div class="divider">
          <span class="divider-text">Or continue with</span>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <%= button_to '/auth/google_oauth2', 
                      data: { turbo: false }, 
                      class: 'material-button secondary' do %>
            <i class="fab fa-google" style="color: #DB4437; margin-right: 8px;"></i>
            Google
          <% end %>
          
          <%= button_to '#', 
                      disabled: true,
                      class: 'material-button secondary' do %>
            <i class="fab fa-facebook" style="color: #1877F2; margin-right: 8px;"></i>
            Facebook
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
