<% content_for :body_class, 'favorites-body' %>
<div class="container mx-auto px-4 py-8">
  <div class="max-w-6xl mx-auto">
    <h1 class="page-name mb-8" style="color: var(--color-text);">
      <%= t('.hello-0') %> <%= current_user&.name || t('.guest-user') %>!
    </h1>

    <% if !current_user || current_user.user_favorites.empty? %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <h2 class="page-name mb-6" style="color: var(--color-text);">My Favorites</h2>
        <p class="page-text mb-6" style="color: var(--color-text); opacity: 0.6;">
          <%= t('.you-dont-have-a') %>
        </p>
        <%= link_to t('.search-for-a-sh'), new_search_url, 
                    class: "form-link",
                    style: "color: var(--color-primary);" %>
      </div>
    <% else %>
      <!-- Favorites Header -->
      <div class="text-center mb-8">
        <h2 class="page-name mb-4" style="color: var(--color-text);">My Favorites</h2>
        <p class="page-text" style="color: var(--color-text); opacity: 0.7;">
          Your favorite spots: <%= current_user.user_favorites.size %>
        </p>
      </div>
      
      <!-- Favorites Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% current_user.user_favorites.each do |fav| %>
          <%= render partial: 'coffeeshops/coffeeshop_card', 
                     locals: { coffeeshop: fav.coffeeshop, search_query: nil } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
